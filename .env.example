# AI MedAssist Environment Variables Template
# Copy this file to .env and update the values

DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:8000

# Seed Data Credentials (Optional)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=your_secure_admin_password
SEED_DEMO_USERNAME=demo
SEED_DEMO_PASSWORD=your_secure_demo_password
